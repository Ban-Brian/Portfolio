\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}Models and Penalty Formulations}{2}{subsection.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Hyperparameter Search Grids}{2}{subsection.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Confusion Matrices}{3}{subsection.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Confusion matrices on the 1{,}000-sample test set. The hardest inter-class confusions---$3\leftrightarrow 5$, $4\leftrightarrow 9$, and $7\leftrightarrow 1$---appear across \emph  {all} models, revealing genuine visual ambiguity rather than model-specific failure. RBF SVM (bottom-right) has the sparsest off-diagonal. The unpenalised logistic model (top-left) shows noticeably more scattered errors, confirming that regularisation is necessary at this sample size.}}{3}{figure.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}Coefficient Shrinkage and Spatial Structure}{4}{subsection.2.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Coefficient weight maps reshaped to $28\!\times \!28$ pixels. \textbf  {Ridge} (top row): smooth, broadly non-zero patterns reflecting the full digit silhouette---every pixel contributes, with larger weights in stroke areas. \textbf  {Lasso} (middle): many background pixels are exactly zero (grey), retaining signal only in ink-heavy regions---sparsity is visually evident. \textbf  {Elastic Net} (bottom): a qualitative intermediate: sparser than Ridge yet smoother than Lasso, inheriting the stability of $\ell _2$ in the correlated pixel neighbourhood. Note: pixels are StandardScaler-normalised, which amplifies low-variance corner pixels; the spatial patterns are qualitatively valid for comparing penalty types.}}{4}{figure.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Overall Model Comparison}{5}{subsection.2.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Left}: test accuracy for all frequentist models (blue) and the representative Bayesian binary-task results (coral, digits 3\,vs.\,8). \textbf  {Right}: log-loss for the subset of models that output calibrated probabilities. RBF SVM achieves the highest accuracy ($\approx $96\%) but cannot produce log-loss without Platt scaling. Among probabilistic models, Ridge LR achieves the lowest log-loss (best calibration), consistent with its log-likelihood objective.}}{5}{figure.4}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}Part C\,: Bayesian Classification and Shrinkage}{5}{section.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}Setup: Binary Subset (Digits 3 vs.\ 8)}{5}{subsection.3.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Frequentist--Bayesian Correspondence}{5}{subsection.3.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Model Specification (PyMC, NUTS)}{6}{subsection.3.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(i) Gaussian Prior (Ridge analogue)}{6}{section*.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(ii) Laplace Prior (Lasso analogue)}{6}{section*.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(iii) Horseshoe Prior (Extension --- non-centred form)}{6}{section*.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Posterior Predictive Probabilities}{6}{subsection.3.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Posterior Summaries and Performance}{6}{subsection.3.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Shrinkage Pattern Comparison}{7}{subsection.3.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Sorted $|\hat  \beta _q|$ (posterior mean) across the 30 PCA dimensions. \textbf  {Gaussian} (blue): smooth, approximately exponential decay---all components receive moderate, uniform shrinkage, consistent with the Ridge analogy. \textbf  {Laplace} (pink): steeper initial drop with a longer flat tail, concentrating information in the top 5--8 ``stroke-relevant'' principal directions. \textbf  {Horseshoe} (purple): pronounced spike-and-slab profile---near-zero shrinkage for the top 6--8 components and essentially complete shrinkage for the remaining ones. This adaptive property is the defining advantage of the Horseshoe over both Gaussian and Laplace priors.}}{7}{figure.5}\protected@file@percent }
