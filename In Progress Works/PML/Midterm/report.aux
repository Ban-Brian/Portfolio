\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces One image per digit from the training set. Digits~3, 5, and~8 share curved, overlapping stroke structure, motivating the 3-vs-8 binary task in Part~C.}}{1}{figure.1}\protected@file@percent }
