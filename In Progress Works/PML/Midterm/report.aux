\@writefile{toc}{\contentsline {subsection}{\numberline {3.7}Shrinkage Comparison}{7}{subsection.3.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Sorted $|\hat  \beta _q|$ (posterior mean) across 30 PCA dimensions. \textbf  {Gaussian}: smooth exponential decay --- uniform shrinkage. \textbf  {Laplace}: steeper initial drop, concentrating weight on the top ``stroke-relevant'' PCA directions. \textbf  {Horseshoe}: pronounced spike-and-slab profile --- near-zero shrinkage on dominant components, complete shrinkage on the rest.}}{7}{figure.5}\protected@file@percent }
