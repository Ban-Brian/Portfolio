test_data <- training_data[-train_idx, ]
# Train logistic regression model
model <- glm(home_win ~ ., data = train_data, family = binomial())
# Evaluate model
test_predictions <- predict(model, test_data, type = "response")
test_accuracy <- mean((test_predictions > 0.5) == test_data$home_win)
cat(paste("Model accuracy on test set:", round(test_accuracy, 3), "\n"))
