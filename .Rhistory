prob_away = 1 - predictions,
pred_winner = ifelse(prob_home > 0.5, home_team, away_team),
confidence = abs(prob_home - 0.5) * 2
) %>%
dplyr::select(season, week, home_team, away_team, prob_home, prob_away, pred_winner, confidence) %>%
dplyr::arrange(desc(confidence))
cat(paste("\nPredictions for Week", current_week, ":\n"))
print(pred_results, n = nrow(pred_results))
