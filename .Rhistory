if (!is.null(model)) {
# model exists -> predict probabilities
model_feats <- diff_feats_existing
# ensure model_feats exist in pred_df, else set to zero
model_feats <- intersect(model_feats, names(pred_df))
if (length(model_feats) == 0) stop("Model features not available in pred_df.")
pred_mat <- pred_df %>% dplyr::select(all_of(model_feats)) %>% dplyr::mutate(across(everything(), ~ifelse(is.na(.),0,.)))
probs <- predict(model, newdata = pred_mat, type = "response")
pred_df <- pred_df %>% dplyr::mutate(prob_home = probs, prob_away = 1-prob_home,
pred_winner = ifelse(prob_home > 0.5, home_team, away_team),
confidence = abs(prob_home - 0.5) * 2)
cat("\nPredictions (model):\n")
print(pred_df %>% dplyr::select(season, week, gameday, away_team, home_team, prob_home, prob_away, pred_winner, confidence), n = nrow(pred_df))
# Write csv
out_name <- paste0("predictions_week_", current_week, "_season_", current_season, ".csv")
readr::write_csv(pred_df %>% dplyr::select(season, week, gameday, away_team, home_team, prob_home, prob_away, pred_winner, confidence), out_name)
cat("Wrote predictions to", out_name, "\n")
} else {
# fallback heuristic: slight home advantage + injury diff and epa diff (if available)
cat("\nUsing fallback heuristic predictions...\n")
pred_df <- pred_df %>% dplyr::mutate(
prob_home = 0.55 + 0.01 * (d_epa_per_play %||% 0) - 0.005 * (d_injury_score %||% 0),
prob_home = pmin(pmax(prob_home, 0.01), 0.99),
prob_away = 1 - prob_home,
pred_winner = ifelse(prob_home > 0.5, home_team, away_team),
confidence = abs(prob_home - 0.5) * 2
)
print(pred_df %>% dplyr::select(season, week, gameday, away_team, home_team, prob_home, prob_away, pred_winner, confidence), n = nrow(pred_df))
out_name <- paste0("predictions_week_", current_week, "_season_", current_season, "_fallback.csv")
readr::write_csv(pred_df %>% dplyr::select(season, week, gameday, away_team, home_team, prob_home, prob_away, pred_winner, confidence), out_name)
cat("Wrote fallback predictions to", out_name, "\n")
}
cat("Done.\n")
