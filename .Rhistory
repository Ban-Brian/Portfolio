cat("\nModel Summary:\n")
cat(paste("Games predicted:", nrow(pred_results), "\n"))
cat(paste("Average confidence:", round(mean(pred_results$confidence), 3), "\n"))
cat(paste("Home team favored:", sum(pred_results$prob_home > 0.5), "times\n"))
